{
    "name": "@booking/nest",
    "version": "0.1.0",
    "description": "NestJS booking module for @booking packages",
    "private": false,
    "main": "./dist/index.js",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.mjs",
            "require": "./dist/index.js"
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsup",
        "dev": "tsup --watch",
        "typecheck": "tsc --noEmit",
        "clean": "rimraf dist"
    },
    "dependencies": {
        "@booking/shared": "workspace:*",
        "@nestjs/mapped-types": "^2.1.0",
        "bcrypt": "^5.1.1",
        "class-transformer": "^0.5.1",
        "class-validator": "^0.15.1",
        "passport": "^0.7.0",
        "passport-jwt": "^4.0.1",
        "resend": "^4.0.0"
    },
    "peerDependencies": {
        "@nestjs/common": "^10.0.0",
        "@nestjs/core": "^10.0.0",
        "@nestjs/event-emitter": "^2.0.0",
        "@nestjs/jwt": "^10.0.0",
        "@nestjs/passport": "^10.0.0",
        "@nestjs/schedule": "^4.0.0",
        "reflect-metadata": "^0.2.0",
        "typeorm": "^0.3.0"
    },
    "devDependencies": {
        "@nestjs/common": "^10.0.0",
        "@nestjs/core": "^10.0.0",
        "@nestjs/event-emitter": "^2.0.0",
        "@nestjs/jwt": "^10.0.0",
        "@nestjs/passport": "^10.0.0",
        "@nestjs/schedule": "^4.0.0",
        "@nestjs/typeorm": "^10.0.2",
        "@swc/core": "^1.15.18",
        "@types/bcrypt": "^6.0.0",
        "@types/passport-jwt": "^4.0.1",
        "reflect-metadata": "^0.2.0",
        "rimraf": "^6.0.1",
        "tsup": "^8.3.5",
        "typeorm": "^0.3.0",
        "typescript": "^5.7.2"
    }
}