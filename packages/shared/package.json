{
    "name": "@booking/shared",
    "version": "0.1.0",
    "description": "Shared types, enums and constants for @booking packages",
    "private": false,
    "main": "./dist/index.js",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.mjs",
            "require": "./dist/index.js"
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsup",
        "dev": "tsup --watch",
        "typecheck": "tsc --noEmit",
        "clean": "rimraf dist"
    },
    "devDependencies": {
        "tsup": "^8.3.5",
        "typescript": "^5.7.2",
        "rimraf": "^6.0.1"
    }
}